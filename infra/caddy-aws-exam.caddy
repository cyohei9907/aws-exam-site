# ---------- AWS Exam Practice Site ----------
aws.cyohei.net {
    encode zstd gzip

    reverse_proxy 127.0.0.1:3001 {
        header_up X-Real-IP {remote_host}
    }

    log {
        output file /var/log/caddy/aws-exam.log {
            roll_size 100mb
            roll_keep 7
        }
    }
}
